        subagent_type: ~
        status: completed
        is_backgrounded: true
        description: cargo test --tests
        summary: tests passed
        total_tokens: ~
        duration_ms: 12000
        last_tool_name: Bash
        error: ~
        end_time_ms: ~
  status:
    type: complete
    reason: stop
  streaming: ~
